#!/bin/bash
# agent-tmux - Minimal tmux-based service runner for AI agents
# Usage: agent-tmux <command> --path <path> [--cmd <command>]

set -euo pipefail

SESSION="agent-dev"
PROJECT_PATH=""
COMMAND=""

# Sanitize a string for use in tmux window names
sanitize() {
    local s="$1"
    s="${s//\//_}"
    s=$(echo "$s" | sed 's/[^A-Za-z0-9_-]/_/g')
    s=$(echo "$s" | sed 's/_\+/_/g')
    s="${s#_}"
    s="${s%_}"
    echo "$s"
}

# Derive window name from path (project_branch format)
derive_window_name() {
    local path="$1"
    local repo_name branch_name

    if [[ ! -d "$path" ]]; then
        echo "Error: path does not exist: $path" >&2
        exit 1
    fi

    if git -C "$path" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        repo_name=$(basename -s .git "$(git -C "$path" config --get remote.origin.url)" 2>/dev/null || basename "$(git -C "$path" rev-parse --show-toplevel)")
        branch_name=$(git -C "$path" symbolic-ref --quiet --short HEAD 2>/dev/null || echo "detached")
        repo_name=$(sanitize "$repo_name")
        branch_name=$(sanitize "$branch_name")
        echo "${repo_name}_${branch_name}"
    else
        repo_name=$(basename "$path")
        repo_name=$(sanitize "$repo_name")
        echo "$repo_name"
    fi
}

ensure_session() {
    if ! tmux has-session -t "$SESSION" 2>/dev/null; then
        tmux new-session -d -s "$SESSION" -n "__default__"
    fi
}

window_exists() {
    local window="$1"
    tmux list-windows -t "$SESSION" -F "#{window_name}" 2>/dev/null | grep -q "^${window}$"
}

is_shell_command() {
    local cmd="$1"
    case "$cmd" in
        ""|bash|zsh|sh|fish|dash|ksh|tcsh|csh)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

window_has_running_program() {
    local window="$1"
    local pane_dead pane_cmd

    while IFS='|' read -r pane_dead pane_cmd; do
        if [[ "$pane_dead" == "0" ]] && ! is_shell_command "$pane_cmd"; then
            return 0
        fi
    done < <(tmux list-panes -t "${SESSION}:${window}" -F '#{pane_dead}|#{pane_current_command}' 2>/dev/null)

    return 1
}

wait_for_window_idle() {
    local window="$1"
    local attempts="${2:-50}"
    local i

    for ((i = 0; i < attempts; i++)); do
        if ! window_has_running_program "$window"; then
            return 0
        fi
        sleep 0.1
    done

    return 1
}

parse_common_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --path)
                PROJECT_PATH="$2"
                shift 2
                ;;
            --cmd)
                shift
                COMMAND="$*"
                break
                ;;
            *)
                shift
                ;;
        esac
    done
}

# Start or ensure a service is running
cmd_start() {
    parse_common_args "$@"

    [[ -n "$PROJECT_PATH" ]] || { echo "Error: --path required" >&2; exit 1; }
    [[ -n "$COMMAND" ]] || { echo "Error: --cmd required" >&2; exit 1; }

    local window
    window=$(derive_window_name "$PROJECT_PATH")

    ensure_session

    if window_exists "$window"; then
        if window_has_running_program "$window"; then
            echo "Already running: ${SESSION}:${window} (RUNNING)"
            return 0
        fi

        tmux send-keys -t "${SESSION}:${window}" "$COMMAND" Enter
        echo "Started: ${SESSION}:${window}"
        return 0
    fi

    tmux new-window -d -t "$SESSION" -n "$window" -c "$PROJECT_PATH"
    tmux send-keys -t "${SESSION}:${window}" "$COMMAND" Enter
    echo "Started: ${SESSION}:${window}"
}

# Restart a service (force fresh process)
cmd_restart() {
    parse_common_args "$@"

    [[ -n "$PROJECT_PATH" ]] || { echo "Error: --path required" >&2; exit 1; }
    [[ -n "$COMMAND" ]] || { echo "Error: --cmd required" >&2; exit 1; }

    local window
    window=$(derive_window_name "$PROJECT_PATH")

    ensure_session

    if window_exists "$window"; then
        if window_has_running_program "$window"; then
            tmux send-keys -t "${SESSION}:${window}" C-c
            wait_for_window_idle "$window" || {
                echo "Error: existing command did not stop: ${SESSION}:${window}" >&2
                exit 1
            }
        fi

        tmux send-keys -t "${SESSION}:${window}" "$COMMAND" Enter
        echo "Restarted: ${SESSION}:${window}"
        return 0
    fi

    tmux new-window -d -t "$SESSION" -n "$window" -c "$PROJECT_PATH"
    tmux send-keys -t "${SESSION}:${window}" "$COMMAND" Enter
    echo "Started: ${SESSION}:${window}"
}

# Stop a service
cmd_stop() {
    parse_common_args "$@"

    [[ -n "$PROJECT_PATH" ]] || { echo "Error: --path required" >&2; exit 1; }

    local window
    window=$(derive_window_name "$PROJECT_PATH")

    if ! window_exists "$window"; then
        echo "Service not found: ${SESSION}:${window}" >&2
        exit 1
    fi

    tmux send-keys -t "${SESSION}:${window}" C-c
    echo "Stopped: ${SESSION}:${window}"
}

# Check if window exists for path
cmd_exists() {
    parse_common_args "$@"

    [[ -n "$PROJECT_PATH" ]] || { echo "Error: --path required" >&2; exit 1; }

    local window
    window=$(derive_window_name "$PROJECT_PATH")

    if ! tmux has-session -t "$SESSION" 2>/dev/null; then
        exit 1
    fi

    window_exists "$window"
}

# Get window name for path
cmd_window() {
    parse_common_args "$@"

    [[ -n "$PROJECT_PATH" ]] || { echo "Error: --path required" >&2; exit 1; }

    derive_window_name "$PROJECT_PATH"
}

# Show status
cmd_status() {
    parse_common_args "$@"

    [[ -n "$PROJECT_PATH" ]] || { echo "Error: --path required" >&2; exit 1; }

    local window
    window=$(derive_window_name "$PROJECT_PATH")

    echo "Session: $SESSION"
    if ! tmux has-session -t "$SESSION" 2>/dev/null; then
        echo "  Status: NOT RUNNING"
        return
    fi
    echo "  Status: RUNNING"

    if ! window_exists "$window"; then
        echo "  Window: ${window} - NOT FOUND"
        return
    fi

    if window_has_running_program "$window"; then
        echo "  Window: ${window} - RUNNING"
        return
    fi

    echo "  Window: ${window} - IDLE"
}

# Show usage
cmd_usage() {
    cat <<'EOF'
Usage: agent-tmux <command> --path <path> [--cmd <command>]

Commands:
  start --path <path> --cmd <command>   Start if idle, or report existing running service
  restart --path <path> --cmd <command> Force restart a service
  stop --path <path>                    Stop a service (send C-c)
  status --path <path>                  Show status (RUNNING/IDLE)
  exists --path <path>                  Check if window exists (exit code 0/1)
  window --path <path>                  Print window name for path

Session:
  Shared tmux session: agent-dev
  Window: <project>_<branch> (derived from path's git info)

Examples:
  agent-tmux start --path ~/myproject --cmd "npm run dev"
  agent-tmux exists --path ~/myproject && echo "running"
  agent-tmux window --path ~/myproject
EOF
}

# Main dispatch
case "${1:-}" in
    start)
        shift
        cmd_start "$@"
        ;;
    restart)
        shift
        cmd_restart "$@"
        ;;
    stop)
        shift
        cmd_stop "$@"
        ;;
    status)
        shift
        cmd_status "$@"
        ;;
    exists)
        shift
        cmd_exists "$@"
        ;;
    window)
        shift
        cmd_window "$@"
        ;;
    help|--help|-h|"")
        cmd_usage
        ;;
    *)
        echo "Unknown command: $1" >&2
        cmd_usage
        exit 1
        ;;
esac
